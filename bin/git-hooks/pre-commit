#!/usr/bin/env bash
set -e

# Env guards
if [ -n "$CI" ]; then
  echo "CI environment detected. Skipping pre-commit hook."
  exit 0
fi

if [ "$APP_ENV" = "production" ] || [ "$LARAVEL_ENV" = "production" ]; then
  echo "Production environment detected. Skipping pre-commit hook."
  exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT" || exit 1

if ! command -v ./vendor/bin/pint >/dev/null 2>&1 && ! command -v pint >/dev/null 2>&1; then
  echo "Laravel Pint not found (./vendor/bin/pint or pint). Skipping."
  exit 0
fi

echo "Running Laravel Pint before commit..."

if [ -x "./vendor/bin/pint" ]; then
  ./vendor/bin/pint --preset laravel
else
  pint --preset laravel
fi

git add .

echo "Pint finished and changes added."
