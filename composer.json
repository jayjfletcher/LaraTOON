{
    "name": "jayi/toon",
    "description": "TOON (Token-Oriented Object Notation) v3.3 encoder and decoder for Laravel",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Jayi\\Toon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jayi\\Toon\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jayi\\Toon\\ToonServiceProvider"
            ],
            "aliases": {
                "Toon": "Jayi\\Toon\\Facades\\Toon"
            }
        },
        "pest": {
            "plugins": [
                "Jayi\\Toon\\Overrides\\Laravel\\Pao\\Plugin"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
